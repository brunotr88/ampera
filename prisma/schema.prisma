  SEISMABONUS_85
  GREEN_BONUS_36
  BARRIER_REMOVAL_75
  CHARGING_STATION_80
  SUPERBONUS_110
  SUPERBONUS_90
  SUPERBONUS_70
  SUPERBONUS_65
  CONTO_TERMICO
  CONTO_TERMICO_PA
  ELECTRIC_RENOVATION_50
  DOMOTIC_BONUS_65
  PV_SELF_CONSUMPTION
  OTHER
}

enum IncentiveStatus {
  DRAFT
  ELIGIBLE
  DOCUMENTS_READY
  BANK_TRANSFER_DONE
  ENEA_SUBMITTED
  COMPLETED
  CANCELLED
}

// =====================================================================
// PRIVACY DOCUMENTS - GDPR informative + consensi tracciati
// =====================================================================

model PrivacyDocument {
  id           String   @id @default(cuid())
  tenantId     String
  type         PrivacyDocType
  audience     String
  subjectName  String?
  subjectEmail String?
  subjectFiscalCode String?
  customerId   String?
  userId       String?
  version      String   @default("1.0")
  contentHtml  String?
  signedAt     DateTime?
  signatureDataUrl String?
  signerName   String?
  ipAddress    String?
  userAgent    String?
  consentsJson Json?
  pdfUrl       String?
  expiresAt    DateTime?
  revokedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

