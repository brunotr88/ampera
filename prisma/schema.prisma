// =====================================================================
// SYSTEM
// =====================================================================

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String?
  userId      String?
  action      String
  entity      String?
  entityId    String?
  meta        Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model NotificationSent {
  id          String   @id @default(cuid())
  tenantId    String
  type        String
  channel     String
  targetEntity String?
  targetId    String?
  recipient   String
  sentAt      DateTime @default(now())
  meta        Json?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type, targetEntity, targetId])
}

model ApiKey {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  hashedKey   String   @unique
  scopes      String[] @default([])
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// =====================================================================
// PRIMA NOTA - Cashbook (cash & bank movements)
// =====================================================================

model Cashbox {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        CashboxType @default(CASH)
  initialBalance Float @default(0)
  currentBalance Float @default(0)
  currency    String   @default("EUR")
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  entries     CashbookEntry[]

  @@index([tenantId])
}

enum CashboxType {
  CASH
  BANK
  CREDIT_CARD
  POS
  PAYPAL
  STRIPE
  OTHER
}

model BankAccount {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  iban        String?
  swift       String?
  bankName    String?
  active      Boolean  @default(true)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model CashbookEntry {
  id            String   @id @default(cuid())
  tenantId      String
  cashboxId     String
  date          DateTime
  direction     CashDirection
  amount        Float
  category      String?
  description   String
  counterpart   String?
  invoiceId     String?
  customerId    String?
  supplierId    String?
  documentRef   String?
  paymentMethod String?
  notes         String?
  attachmentUrl String?
  reconciledAt  DateTime?
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id])
  cashbox       Cashbox   @relation(fields: [cashboxId], references: [id])

  @@index([tenantId])
  @@index([cashboxId])
  @@index([date])
  @@index([direction])
  @@index([category])
}

enum CashDirection {
  IN
  OUT
}

// =====================================================================
// PAYMENT TERMS - Riusabili per quote/invoice
// =====================================================================

model PaymentTerm {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  daysOffset  Int      @default(30)
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// =====================================================================
// SUPPLIERS & PURCHASE ORDERS - Ordini fornitori
// =====================================================================

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  vatNumber   String?
  fiscalCode  String?
  email       String?
  phone       String?
  address     String?
  city        String?
  province    String?
  zip         String?
  contactName String?
  paymentTerms String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  orders      PurchaseOrder[]

  @@index([tenantId])
  @@index([vatNumber])
}

model PurchaseOrder {
  id            String        @id @default(cuid())
  tenantId      String
  supplierId    String
  number        String
  status        PurchaseOrderStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  expectedDate  DateTime?
  receivedDate  DateTime?
  projectId     String?
  warehouseId   String?
  subtotal      Float         @default(0)
  vatTotal      Float         @default(0)
  total         Float         @default(0)
  shippingCost  Float         @default(0)
  notes         String?
  internalNotes String?
  pdfUrl        String?
  createdById   String?
  sentAt        DateTime?
  receivedFully Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  supplier      Supplier      @relation(fields: [supplierId], references: [id])
  createdBy     User?         @relation("PurchaseOrderCreator", fields: [createdById], references: [id])
  lines         PurchaseOrderLine[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  CONFIRMED
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrderLine {
  id           String   @id @default(cuid())
  orderId      String
  position     Int
  materialCode String?
  description  String
  lineNote     String?
  quantity     Float
  receivedQty  Float    @default(0)
  unit         String   @default("pz")
  unitPrice    Float
  vatRate      Float    @default(22)
  total        Float

  order        PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// =====================================================================
// VACATIONS / TIME OFF
// =====================================================================

model VacationRequest {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  type          VacationType @default(VACATION)
  startDate     DateTime
  endDate       DateTime
  halfDayStart  Boolean  @default(false)
  halfDayEnd    Boolean  @default(false)
  reason        String?
  status        VacationStatus @default(PENDING)
  approvedById  String?
  approvedAt    DateTime?
  rejectedReason String?
  attachmentUrl String?
  notifyDaysBefore Int   @default(7)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  user          User     @relation(fields: [userId], references: [id])
  approvedBy    User?    @relation("VacationApprover", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
}

enum VacationType {
  VACATION
  PERMIT
  ILLNESS
  TRAINING
  LEAVE_104
  PARENTAL
  OTHER
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// =====================================================================
// CALENDAR & REMINDERS
// =====================================================================

model CalendarEvent {
  id          String     @id @default(cuid())
  tenantId    String
  ownerId     String
  title       String
  description String?
  type        EventType  @default(MEETING)
  startsAt    DateTime
  endsAt      DateTime
  allDay      Boolean    @default(false)
  location    String?
  color       String?
  customerId  String?
  projectId   String?
  workOrderId String?
  attendeesJson Json?
  reminderMinutesBefore Int @default(60)
  reminderEmailSent Boolean @default(false)
  recurrenceRule String?
  status      EventStatus @default(CONFIRMED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  owner       User     @relation("EventOwner", fields: [ownerId], references: [id])
  reminders   Reminder[]

  @@index([tenantId])
  @@index([ownerId])
  @@index([startsAt])
  @@index([type])
}

enum EventType {
  MEETING
  CALL
  TASK
  INSPECTION
  DEADLINE
  REMINDER
  OTHER
}

enum EventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

model Reminder {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  eventId     String?
  title       String
  body        String?
  remindAt    DateTime
  sentAt      DateTime?
  channel     ReminderChannel @default(EMAIL)
  status      ReminderStatus @default(PENDING)
  recipient   String?
  meta        Json?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
  event       CalendarEvent? @relation(fields: [eventId], references: [id])

  @@index([tenantId])
  @@index([remindAt])
  @@index([status])
}

enum ReminderChannel {
  EMAIL
  PUSH
  SMS
  WHATSAPP
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

// =====================================================================
// ATTACHMENTS - Polymorphic file storage (PDF, images, docs) for any entity
// =====================================================================

model Attachment {
  id           String         @id @default(cuid())
  tenantId     String
  entityType   String
  entityId     String
  fileName     String
  url          String
  category     AttachmentCategory @default(GENERAL)
  mimeType     String?
  sizeBytes    Int            @default(0)
  width        Int?
  height       Int?
  uploadedById String?
  notes        String?
  takenAt      DateTime?
  lat          Float?
  lon          Float?
  createdAt    DateTime       @default(now())

  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  uploadedBy   User?          @relation("AttachmentUploader", fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([category])
}

enum AttachmentCategory {
  GENERAL
  PHOTO
  PDF
  DICO
  CERTIFICATE
  CONTRACT
  PRIVACY_CONSENT
  ID_DOCUMENT
  INVOICE_ATTACHMENT
  PROJECT_PLAN
  TECHNICAL_DRAWING
  SAFETY_DOC
  REPORT_PDF
  OTHER
}

// =====================================================================
// FAQ - Knowledge base interno e per portale cliente
// =====================================================================

model Faq {
  id          String   @id @default(cuid())
  tenantId    String?
  category    String?
  question    String
  answer      String
  audience    FaqAudience @default(ADMIN)
  tags        String[] @default([])
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  sortOrder   Int      @default(0)
  isGlobal    Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId, audience])
  @@index([category])
  @@index([isGlobal])
}

enum FaqAudience {
  ADMIN
  OPERATOR
  CUSTOMER
  PUBLIC
}

// =====================================================================
// ITALIAN TAX INCENTIVES - Agevolazioni fiscali per ristrutturazioni
// =====================================================================

model IncentiveApplication {
  id              String   @id @default(cuid())
  tenantId        String
  customerId      String?
  plantId         String?
  projectId       String?
  invoiceId       String?
  code            String
  type            IncentiveType
  workDescription String
  workStartDate   DateTime?
  workEndDate     DateTime?
  totalAmount     Float    @default(0)
  deductiblePercentage Float
  deductibleAmount Float   @default(0)
  yearsOfRecovery Int      @default(10)
  yearlyAmount    Float    @default(0)
  status          IncentiveStatus @default(DRAFT)
  bankTransferRef String?
  bankTransferDate DateTime?
  bankTransferDescription String?
  enéaProtocol    String?
  enéaSubmittedAt DateTime?
  agenciaProtocol String?
  cessionAccredito Boolean @default(false)
  sconfoFattura   Boolean  @default(false)
  technicalAsseveration Boolean @default(false)
  notes           String?
  metadata        Json?
